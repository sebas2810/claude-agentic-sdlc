# ── Per-seat configuration ── copy to .env.local (gitignored) and fill in ──
# bootstrap.sh WRITES this file for every seat from the committed sdlc.config
# (instance · repo · seats as role:Name · identity) — you only edit it by hand
# for a seat bootstrap didn't create, or to add per-seat secrets/overrides
# (GH_TOKEN · SEAT_MODEL · BOARD_TOKEN_CMD). Each seat gets its own worktree +
# identity so commits and AWS/GitHub calls attribute correctly on one machine.

INSTANCE=<your-instance>            # the seat-file + overlay name (e.g. sammy)

SEAT_ROLE=engineer                      # the enforced TYPE: engineer | quality-engineer | pm |
                                        #   scrum-master | cloud-architect | data-architect | data-scientist
SEAT_NAME=Finn                          # the FREE name — display label for this seat (e.g. Finn, Cas)

# Git commit identity (applied per-worktree, never shared)
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="you@example.com"

# AWS — which configured profile this seat uses (when several exist)
AWS_PROFILE=<your-aws-profile>

# GitHub — set ONLY if this seat uses a different account than the default `gh` login
# GH_TOKEN=ghp_xxx

# ── Operator-driven (semi-automated) ── read by seat-launch.sh ──
# The HUMAN is the orchestrator: no autonomous loop, no polling, no events, no inbox. Each seat is an
# interactive pane that PULLS its next workload from the board with /check when the operator engages it.
SEAT_LABEL=seat:finn                   # a producer's lane label: seat:<name>, named after the seat
                                        #   (e.g. seat:finn) — /check pulls the next Scoped item carrying it.
                                        #   (quality-engineer / pm / scrum-master key off the role — no lane label.)
BOARD_ID=                              # the Execution project number (e.g. 1) — used by /check + /board
BOARD_OWNER=                           # the project owner login (e.g. your-org)
SEAT_TITLE=                            # optional terminal-window title; default "<Role> - <Name>"

# Model tier — configured in sdlc.config as a role:Name:model triple; bootstrap
# writes the resolved tier here. Defaults by role: pm + quality-engineer
# (judgment + the independent gate) → opus; scrum-master + producers
# (mechanical / volume, backstopped by the gate) → sonnet. Hand-edit to override:
#   SEAT_MODEL=opus     # e.g. an agent-path / infra / data / ML engineer doing hard, novel work
#   SEAT_MODEL=haiku    # e.g. a scrum-master doing pure board mechanics
#   SEAT_MODEL=         # empty → inherit your account default (pass no --model)
# SEAT_MODEL=

# Board-ops own quota (optional): a command that prints a token scoped to board reads/writes — e.g. a
# GitHub App installation token — so /check's GraphQL doesn't share your personal 5,000/hr quota.
# BOARD_TOKEN_CMD="bash /path/to/gh-app-token.sh"
