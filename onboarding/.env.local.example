INSTANCE=<your-instance>            # the seat-file + overlay name (e.g. sammy); generic default below
# ── Per-seat configuration ── copy to .env.local (gitignored) and fill in ──
# Each seat (PM or Engineer) gets its own worktree + identity so commits and
# AWS/GitHub calls attribute correctly when several seats run on one machine.

SEAT_ROLE=engineer                      # the enforced TYPE: engineer | quality-engineer | pm |
                                        #   scrum-master | cloud-architect | data-architect | data-scientist
SEAT_NAME=engineer-2                    # the FREE name — display label for this seat (e.g. Dex, Sam)

# Git commit identity (applied per-worktree, never shared)
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="you@example.com"

# AWS — which configured profile this seat uses (when several exist)
AWS_PROFILE=<your-aws-profile>

# GitHub — set ONLY if this seat uses a different account than the default `gh` login
# GH_TOKEN=ghp_xxx

# ── Operator-driven (semi-automated) ── read by seat-launch.sh ──
# The HUMAN is the orchestrator: no autonomous loop, no polling, no events, no inbox. Each seat is an
# interactive pane that PULLS its next workload from the board with /check when the operator engages it.
SEAT_LABEL=seat:engineer-2             # a producer's lane: /check pulls the next Scoped item carrying
                                        #   this label. (quality-engineer / pm / scrum-master key off the role.)
BOARD_ID=                              # the Execution project number (e.g. 1) — used by /check + /board
BOARD_OWNER=                           # the project owner login (e.g. your-org)
SEAT_TITLE=                            # optional terminal-window title; default "<Role> - <Name>"

# Board-ops own quota (optional): a command that prints a token scoped to board reads/writes — e.g. a
# GitHub App installation token — so /check's GraphQL doesn't share your personal 5,000/hr quota.
# BOARD_TOKEN_CMD="bash /path/to/gh-app-token.sh"
