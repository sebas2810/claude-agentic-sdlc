{
  "kind": "program",
  "title_suffix": "Program",
  "description": "Epic/Initiative program board — the owner+PM strategic surface. Coarser epic lifecycle, not the 7 execution states. Provisioned by onboarding/setup-board.sh.",
  "statusField": {
    "name": "Status",
    "options": [
      { "name": "Proposed", "color": "GRAY", "description": "framed, not yet steered" },
      { "name": "Steered", "color": "BLUE", "description": "scoped into stories with pre-committed AC" },
      { "name": "Active", "color": "YELLOW", "description": "stories in flight (WIP-limited: <= 3 active epics)" },
      { "name": "Done", "color": "GREEN", "description": "all child stories Released" },
      { "name": "Blocked", "color": "RED", "description": "awaiting an owner/strategic decision" }
    ]
  },
  "fields": [
    { "name": "WSJF", "dataType": "NUMBER" },
    { "name": "Priority", "dataType": "SINGLE_SELECT", "options": ["P0", "P1", "P2", "P3"] },
    { "name": "Level", "dataType": "SINGLE_SELECT", "options": ["initiative", "epic"] },
    { "name": "Target", "dataType": "DATE" },
    { "name": "Area", "dataType": "TEXT" }
  ]
}
